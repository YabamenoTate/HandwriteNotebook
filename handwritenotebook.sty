\usepackage{ifthen}
\newcommand{\@isFontCEO}[2]{\ifthenelse{\equal{\f@family}{ceo}}{#1}{#2}}
\newcommand{\LEQQ}{\@isFontCEO\leq{\mathrel{\mathpalette\gl@align<}}}
\newcommand{\GEQQ}{\@isFontCEO\geq{\mathrel{\mathpalette\gl@align>}}}
\newcommand{\gl@align}[2]{\lower.7ex\vbox{\baselineskip\z@skip\lineskip\z@
\ialign{$\m@th#1\hfil##\hfil$\crcr#2\@isFontCEO{\vspace{0.25ex}}{\vspace{-0.8ex}}\crcr-\vspace{-1.2ex}\crcr-\crcr}}}

