% \section の番号の後にドットを付けることを宣言
\newcommand\sectiondot[1]{%
	\expandafter\def\csname @seccntfmt@#1\endcsname##1{%
		\csname the##1\endcsname.\hspace{-1.5ex}
	}
}
% 既存の \section を上書き
\sectiondot{section}

% 内部コマンドの再定義：\@seccntfmt@#1 という名前のコマンドが定義されていればそれを使い、
% そうでなければデフォルトのスタイル（番号+空白）を使うようにする
\renewcommand\@seccntformat[1]{\@ifundefined{@seccntfmt@#1}%
	{\csname the#1\endcsname}% デフォルトのスタイル
	{\csname @seccntfmt@#1\endcsname{#1}}%
}

