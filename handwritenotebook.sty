% \section コマンドのバックアップ
\let\oldsection\section

% \section コマンドの再定義
\renewcommand{\section}[1]{
  \vspace{1cm} % セクション前のスペース
  \oldsection*{#1}
  \vspace{6mm} % セクション後のスペース
}

% \subsectionコマンドの変更
\renewcommand{\subsection}[1]{\par\noindent ＜#1＞\par}
\renewcommand{\subsubsection}[1]{\par\noindent ・#1\par}

% ページ番号を消す
